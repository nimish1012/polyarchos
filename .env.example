# ── core-api ──────────────────────────────────────────────────────────────────
CORE_API_GRPC_PORT=50051
CORE_API_REST_PORT=8080

# ── rag-engine ────────────────────────────────────────────────────────────────
RAG_ENGINE_GRPC_PORT=50052

# ── Neo4j ─────────────────────────────────────────────────────────────────────
RAG_NEO4J_URI=bolt://localhost:7687
RAG_NEO4J_USER=neo4j
RAG_NEO4J_PASSWORD=polyarchos

# ── Milvus ────────────────────────────────────────────────────────────────────
RAG_MILVUS_HOST=localhost
RAG_MILVUS_PORT=19530

# ── LLM provider ──────────────────────────────────────────────────────────────
# Choose one: ollama | openai | google | anthropic
RAG_LLM_PROVIDER=ollama

# ── Ollama (local, offline-safe default) ──────────────────────────────────────
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_OLLAMA_MODEL=mistral:7b-instruct
RAG_OLLAMA_TIMEOUT_S=120

# ── OpenAI ────────────────────────────────────────────────────────────────────
# RAG_LLM_PROVIDER=openai
RAG_OPENAI_API_KEY=sk-...
RAG_OPENAI_MODEL=gpt-4o-mini
RAG_OPENAI_TIMEOUT_S=60

# ── Google Generative AI (Gemini) ─────────────────────────────────────────────
# RAG_LLM_PROVIDER=google
RAG_GOOGLE_API_KEY=AIza...
RAG_GOOGLE_MODEL=gemini-2.0-flash

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# RAG_LLM_PROVIDER=anthropic
RAG_ANTHROPIC_API_KEY=sk-ant-...
RAG_ANTHROPIC_MODEL=claude-sonnet-4-6
RAG_ANTHROPIC_MAX_TOKENS=2048
RAG_ANTHROPIC_TIMEOUT_S=60

# ── Embedding model ───────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
LOG_FORMAT=json
